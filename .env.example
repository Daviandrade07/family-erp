# =============================================================
# Família ERP — variáveis de build (exemplo, SEM SEGREDOS)
# =============================================================
# Estes valores NÃO ficam num arquivo .env em runtime: são injetados no
# build via --dart-define (ver lib/core/config/env.dart). Copie os que
# precisar para o seu comando de build. Nunca versione os valores reais.
#
# Guia de build canônico (web + APK), com os comandos completos: ver BUILD.md.
#
# Exemplo de build web:
#   flutter build web --release --base-href /family-erp/ \
#     --dart-define=SUPABASE_URL=... \
#     --dart-define=SUPABASE_ANON_KEY=... \
#     --dart-define=AI_PROXY_URL=...
#
# Exemplo de build Android:
#   flutter build apk --release \
#     --dart-define=SUPABASE_URL=... \
#     --dart-define=SUPABASE_ANON_KEY=... \
#     --dart-define=AI_PROXY_URL=...

# --- OBRIGATÓRIOS (sem eles o login/Supabase não funciona) ---
# URL do projeto Supabase. Ex.: https://xxxxxxxx.supabase.co
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Chave publishable/anon do Supabase (pode ir no cliente; é pública por design).
SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# --- IA (recomendado: PROXY, sem chave no app) ---
# Edge Function que guarda a chave do Groq no servidor e valida o usuário.
# Formato: <SUPABASE_URL>/functions/v1/ai-proxy
AI_PROXY_URL=https://YOUR_PROJECT.supabase.co/functions/v1/ai-proxy

# --- IA (opcional/avançado: chave direta no cliente) ---
# Use APENAS em builds privados. Em produção prefira o proxy acima.
# AI_API_KEY=gsk_xxx            # chave Groq (OpenAI-compatible)
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# ANTHROPIC_API_KEY=sk-ant-xxx  # alternativa: usar Claude no lugar do Groq
# USE_MOCK_AI=false             # true = motores mock offline (OCR/NLU)

# --- Somente desenvolvimento (NUNCA em build de produção) ---
# Ativam auto-login numa conta de teste. Não passe em APK/PWA distribuído.
# DEV_EMAIL=teste@exemplo.com
# DEV_PASSWORD=trocar

# =============================================================
# Segredo do SERVIDOR (NÃO vai no app, NÃO use --dart-define):
#   GROQ_API_KEY  -> definido como secret da Supabase Edge Function:
#   npx supabase secrets set GROQ_API_KEY=gsk_xxx
# =============================================================
